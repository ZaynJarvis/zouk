# ── Zouk Server ──────────────────────────────────────────────
PUBLIC_URL=http://localhost:7777
GOOGLE_CLIENT_ID=
ALLOW=
ZOUK_SUPERUSERS=
# ZOUK_GUEST_ELEVATED=1        # local testing without OAuth
# ZOUK_IMAGE=ghcr.io/t0saki/zouk:sha-abc1234

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=zouk
POSTGRES_USER=zouk
POSTGRES_PASSWORD=change-me-in-production

# ── OpenViking ──────────────────────────────────────────────
# OV config lives in ~/.openviking/ov.conf (bind-mounted into container).
# See ov.conf.example for the config format.
# Root key — created by: docker compose exec openviking openviking-cli admin create-key --name zouk-root
OPENVIKING_ROOT_KEY=
# OV_DATA_DIR=~/.openviking     # override OV data directory

# ── Ports ───────────────────────────────────────────────────
PORT=7777
PG_PORT=5432
OV_PORT=1933
